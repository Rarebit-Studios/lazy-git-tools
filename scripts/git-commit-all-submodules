#!/usr/bin/env bash
# Commit in all submodules, then in this repo (default message: Update)
set -e
root="$(git rev-parse --show-toplevel)"
msg="${1:-Update}"
cd "$root"
if [ -f .gitmodules ]; then
  git submodule foreach 'git add -A; git commit -m "'"$msg"'" || true'
fi
git add -A
git commit -m "$msg" || true

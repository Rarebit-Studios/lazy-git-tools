#!/usr/bin/env bash
# Login to git using website callback (GitHub device flow)
set -e
GITHUB_CLIENT_ID="${GITHUB_OAUTH_DEVICE_CLIENT_ID:-178c6fc778ccc68e1d6a}"
SCOPE="${GITHUB_LOGIN_SCOPE:-repo,read:org,workflow}"

response=$(curl -s -X POST https://github.com/login/device/code \
  -H "Accept: application/json" \
  -d "client_id=$GITHUB_CLIENT_ID" \
  -d "scope=$SCOPE")

device_code=$(echo "$response" | sed -n 's/.*"device_code":"\([^"]*\)".*/\1/p')
user_code=$(echo "$response" | sed -n 's/.*"user_code":"\([^"]*\)".*/\1/p')
verification_uri=$(echo "$response" | sed -n 's/.*"verification_uri":"\([^"]*\)".*/\1/p')
interval=$(echo "$response" | sed -n 's/.*"interval":\([0-9]*\).*/\1/p')

if [ -z "$device_code" ] || [ -z "$verification_uri" ]; then
  echo "Failed to get device code. Check network or try again." >&2
  exit 1
fi

echo "Open this URL in your browser and enter the code: $user_code"
echo "  $verification_uri"
echo ""

# Open browser if possible
if command -v xdg-open &>/dev/null; then
  xdg-open "$verification_uri" 2>/dev/null &
elif command -v open &>/dev/null; then
  open "$verification_uri" 2>/dev/null &
fi

echo "Waiting for you to authorize..."
while true; do
  sleep "${interval:-5}"
  token_response=$(curl -s -X POST https://github.com/login/oauth/access_token \
    -H "Accept: application/json" \
    -d "client_id=$GITHUB_CLIENT_ID" \
    -d "device_code=$device_code" \
    -d "grant_type=urn:ietf:params:oauth:grant-type:device_code") || true

  access_token=$(echo "$token_response" | sed -n 's/.*"access_token":"\([^"]*\)".*/\1/p')
  error=$(echo "$token_response" | sed -n 's/.*"error":"\([^"]*\)".*/\1/p')

  if [ -n "$access_token" ]; then
    break
  fi
  if [ "$error" = "expired_token" ] || [ "$error" = "access_denied" ]; then
    echo "Authorization failed or expired ($error). Try again." >&2
    exit 1
  fi
  # authorization_pending = still waiting
done

# Store credential for GitHub HTTPS
host="github.com"
git config --global credential.https://${host}.helper store 2>/dev/null || true
cred_file="${HOME}/.git-credentials"
grep -v "https://.*@${host}" "$cred_file" 2>/dev/null > "${cred_file}.tmp" || true
echo "https://${access_token}:x-oauth-basic@${host}" >> "${cred_file}.tmp" 2>/dev/null
mv "${cred_file}.tmp" "$cred_file" 2>/dev/null || echo "https://${access_token}:x-oauth-basic@${host}" >> "$cred_file"
chmod 600 "$cred_file" 2>/dev/null || true
echo "Logged in to GitHub. Git over HTTPS will use this token."
